<%=render 'layouts/header'%>

<div class="container plat new">
    <%=form_for @plat, :url => @plat.persisted? ? app_plat_path(@plat.app,@plat) : app_plats_path, :html => { :method => @plat.new_record? ? "post" : "put", class: "app_form" } do |f|%>

    <%= hidden_field_tag "plat[app_id]", @plat.app_id %>

    <div class="title"><span> <%=@plat.persisted? ? "修改渠道" : "新建渠道" %> </span></div>

    <div class="form-group">
      <label for="plat_name">渠道名称*：</label>
      <%= f.text_field :name, class:"form-control", required:true %>
    </div>

    <div class="form-group">
      <label for="plat_name">校验包名：</label>
      <%= f.text_field :bundle_id, class:"form-control", placeholder:"不填则不校验,支持通配符*号" %>
    </div>

    <div class="form-group">
      <label for="plat_name">包类型*：</label>
      <%= f.select(:plat_name,pkg_selectable_map,{},{class:"form-control"}) %>
    </div>

    <div class="form-group">
      <label for="plat_name">不允许重复包：</label>
      <%= f.select(:pkg_uniq,{'YES'=>'true','NO'=>'false'},{},{class:"form-control"}) %>
    </div>

    <div id="hap-cert-fields" style="<%= 'display:none;' unless @plat.harmonyos? || params.dig(:plat, :plat_name) == 'harmonyos' %>">
    <div class="form-group">
      <label>鸿蒙内部测试证书（.p12）<small class="text-muted"> — 用于 OTA manifest 自动签名</small></label>
      <% if @plat.persisted? && @plat.hap_cert.present? %>
        <p class="help-block">
          已上传：<code><%= File.basename(@plat.hap_cert.path.to_s) %></code>
          &nbsp;（重新选择文件可替换）
        </p>
      <% end %>
      <%= f.file_field :hap_cert, accept: ".p12" %>
    </div>
    <div class="form-group">
      <label>p12 证书密码</label>
      <%= f.password_field :hap_cert_password, class:"form-control",
            placeholder: "留空则保持不变",
            autocomplete: "new-password" %>
    </div>
    </div>

    <script>
      (function() {
        var select = document.querySelector('select[name="plat[plat_name]"]');
        var certFields = document.getElementById('hap-cert-fields');
        if (select && certFields) {
          select.addEventListener('change', function() {
            certFields.style.display = this.value === 'harmonyos' ? '' : 'none';
          });
        }
      })();
    </script>

    <% if @plat.persisted? %>
      <%=f.submit "保存", class:"btn btn-primary ui-plat"%>
    <% else %>
      <%=f.submit "新建", class:"btn btn-primary ui-plat"%>
    <% end %>
    
  <%end%>
</div>